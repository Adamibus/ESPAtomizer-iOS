    <scenes>
        <!-- Launch screen: FLAT charcoal, nothing else. The orb used to live here,
             but the iOS app-open animation scales the launch screen up from the
             icon — and a detailed orb scaling looked shaky/blurry. Scaling a flat
             color is imperceptible, so the open reads clean; the orb then fades in
             via SplashView in ESPAtomizer_iOSApp once the app is on screen.
             bg = Theme.charcoalDeep #171A1E. -->
        <scene sceneID="EHf-IW-A2E">
            <objects>
                <viewController id="01J-lp-oVM" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="Ze5-6b-2t3">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <viewLayoutGuide key="safeArea" id="6Tk-OE-BBY"/>
                        <color key="backgroundColor" red="0.09" green="0.10" blue="0.12" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                    </view>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="iYj-Kq-Ea1" userLabel="First Responder" customClass="UIResponder" sceneMemberID="firstResponder"/>
