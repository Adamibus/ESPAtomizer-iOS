EESchema-LIBRARY Version 2.4
#
# ThermoADC symbol library (generic thermocouple ADC SOIC-8)
#
DEF ThermoADC_SOIC8 U 0 40 Y Y 1 F N
F0 "U" 0 0 60 H V C CNN
F1 "ThermoADC_SOIC8" 0 -200 60 H V C CNN
F2 "" 0 0 60 H V C CNN
F3 "" 0 0 60 H V C CNN
PINATTR PinTypes=Passive
DRAW
S -200 200 200 -200 0 1
X VCC 2 1 200 100 R 50 50 1 1 P
X SCK 3 1 -50 50 L 50 50 1 1 P
X CS 4 1 -50 0 L 50 50 1 1 P
X SDI 5 1 -50 -50 L 50 50 1 1 P
X SDO 6 1 50 -50 R 50 50 1 1 P
X GND 7 1 50 0 R 50 50 1 1 P
X T+ 8 1 50 50 R 50 50 1 1 P
X T- 1 1 50 150 R 50 50 1 1 P
ENDDRAW
ENDDEF

#
ENDLIB
