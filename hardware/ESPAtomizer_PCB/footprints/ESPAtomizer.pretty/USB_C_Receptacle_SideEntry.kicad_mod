(
  module "USB_C_Receptacle_SideEntry" (layer F.Cu) (tedit 64B5E3D4)
    (descr "Generic USB-C side-entry receptacle (simplified pad map)")
    (tags "usb-c receptacle usb-c-typec side-entry")
    (attr smd)
    (fp_text reference REF** (at 0 -3.5) (layer F.SilkS)
      (effects (font (size 1 1) (thickness 0.15)))
    )
    (fp_text value USB-C (at 0 3.5) (layer F.Fab)
      (effects (font (size 1 1) (thickness 0.15)))
    )
    (pad VBUS1 smd rect (at -3.5 0.0) (size 1.2 1.0) (layers F.Cu F.Paste F.Mask) (net 0))
    (pad VBUS2 smd rect (at -2.4 0.0) (size 1.2 1.0) (layers F.Cu F.Paste F.Mask) (net 0))
    (pad CC1 smd rect (at -1.2 0.0) (size 0.8 0.9) (layers F.Cu F.Paste F.Mask) (net 0))
    (pad D- smd rect (at 0.0 0.0) (size 0.8 0.9) (layers F.Cu F.Paste F.Mask) (net 0))
    (pad D+ smd rect (at 1.2 0.0) (size 0.8 0.9) (layers F.Cu F.Paste F.Mask) (net 0))
    (pad SBU1 smd rect (at 2.4 0.0) (size 0.8 0.9) (layers F.Cu F.Paste F.Mask) (net 0))
    (pad SBU2 smd rect (at 3.5 0.0) (size 0.8 0.9) (layers F.Cu F.Paste F.Mask) (net 0))
    (pad GND1 smd rect (at 0.0 -2.5) (size 3.0 1.6) (layers F.Cu F.Paste F.Mask) (net 0))
)
